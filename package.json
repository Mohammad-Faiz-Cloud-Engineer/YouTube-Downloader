{
  "name": "yt-downloader",
  "version": "1.0.0",
  "description": "Full-featured YouTube Downloader",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "lint": "eslint server.js public/script.js",
    "lint:fix": "eslint server.js public/script.js --fix",
    "format": "prettier --write \"**/*.{js,json,css,html,md}\"",
    "docker:build": "docker build -t yt-downloader .",
    "docker:run": "docker run -p 3000:3000 yt-downloader",
    "docker:compose": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "youtube-dl-exec": "^3.1.4"
  },
  "devDependencies": {
    "eslint": "^10.1.0",
    "nodemon": "^3.0.2",
    "prettier": "^3.2.5"
  },
  "engines": {
    "node": ">=14.0.0"
  }
}
